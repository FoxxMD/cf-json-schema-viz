{
  "name": "cf-schema-viz-demo",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "concurrently -k -n worker,vite -c blue,magenta \"npm run dev:worker\" \"npm run dev:vite\"",
    "dev": "npm run start",
    "dev:worker": "wrangler dev",
    "dev:vite": "vite",
    "build": "vite build",
    "deploy": "npm run build && wrangler deploy",
    "preview": "npm run build && wrangler dev"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@phosphor-icons/react": "^2.1.10",
    "hono": "^4.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241230.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "wrangler": "^4.69.0"
  }
}
